# Copy this file to .env and fill in your real values. Never commit the real .env file.

# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/task_dashboard

# MongoDB Atlas (cloud, free tier) — get this from Atlas > Connect > Drivers:
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/task_dashboard?retryWrites=true&w=majority

PORT=5000
